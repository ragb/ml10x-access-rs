{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ragb/ml10x-access-rs/schemas/preset.schema.json",
  "title": "ML10X Preset",
  "description": "One preset on the Morningstar ML10X loop switcher. Note: the ML10X has no per-preset MIDI-message list (that's an MC-series feature); this schema deliberately omits any `midi_messages` field.",
  "type": "object",
  "required": ["preset"],
  "additionalProperties": false,
  "properties": {
    "preset": {
      "type": "object",
      "required": ["bank", "number", "name", "body"],
      "additionalProperties": false,
      "properties": {
        "bank": {
          "description": "Which of the 4 banks this preset lives in (matches the editor's 'Bank 1'..'Bank 4' labels).",
          "type": "integer",
          "minimum": 1,
          "maximum": 4
        },
        "number": {
          "description": "Position within the bank (0 through 127, matching the device's MIDI Program Change numbering).",
          "type": "integer",
          "minimum": 0,
          "maximum": 127
        },
        "name": {
          "description": "Display name shown on the ML10X.",
          "type": "string",
          "maxLength": 16
        },
        "spillover": {
          "description": "When the user switches to a different preset, the chosen loop's trail audio continues sounding (provided that loop is bypassed in the next preset). Set per output. 'nothing' is the default.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "output_tip":  { "$ref": "#/$defs/spilloverTarget" },
            "output_ring": { "$ref": "#/$defs/spilloverTarget" }
          }
        },
        "body": {
          "description": "Mode-specific routing. Simple is a linear chain with per-loop bypass; Advanced is an arbitrary connection graph with no per-loop bypass (the firmware does not honour it in Advanced presets).",
          "oneOf": [
            { "$ref": "#/$defs/simpleBody" },
            { "$ref": "#/$defs/advancedBody" }
          ]
        }
      }
    }
  },
  "$defs": {
    "connectorRef": {
      "type": "string",
      "enum": [
        "a_tip", "a_ring",
        "b_tip", "b_ring",
        "c_tip", "c_ring",
        "d_tip", "d_ring",
        "e_tip", "e_ring",
        "input_tip", "input_ring",
        "output_tip", "output_ring"
      ]
    },
    "spilloverTarget": {
      "type": "string",
      "enum": [
        "nothing",
        "input_tip", "input_ring",
        "a_tip", "a_ring",
        "b_tip", "b_ring",
        "c_tip", "c_ring",
        "d_tip", "d_ring",
        "e_tip", "e_ring"
      ],
      "default": "nothing"
    },
    "simpleBody": {
      "type": "object",
      "required": ["mode", "chain"],
      "additionalProperties": false,
      "properties": {
        "mode": { "const": "simple" },
        "chain": {
          "description": "Linear signal chain: ordered hops from sources through loops to outputs. Each hop may set `bypass: true` to skip that loop.",
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from_connector", "to_connector"],
            "additionalProperties": false,
            "properties": {
              "from_connector": { "$ref": "#/$defs/connectorRef" },
              "to_connector":   { "$ref": "#/$defs/connectorRef" },
              "bypass":         { "type": "boolean", "default": false }
            }
          }
        }
      }
    },
    "advancedBody": {
      "type": "object",
      "required": ["mode", "connections"],
      "additionalProperties": false,
      "properties": {
        "mode": { "const": "advanced" },
        "connections": {
          "description": "Routing graph: each edge connects a source to a destination. Branching and merging are allowed. No `bypass` field — the firmware ignores per-loop bypass in Advanced presets.",
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from_connector", "to_connector"],
            "additionalProperties": false,
            "properties": {
              "from_connector": { "$ref": "#/$defs/connectorRef" },
              "to_connector":   { "$ref": "#/$defs/connectorRef" }
            }
          }
        }
      }
    }
  }
}
